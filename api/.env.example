PRISM_ALERTS_DATABASE_URL='postgresql://postgres:!ChangeMe!@127.0.0.1:54321/postgres'

# --- Alert workers (threshold + AA storm/flood emails; see api/crons/cron_*_alert_run.sh) ---
# Production: loaded from AWS Secrets Manager via api/set_envs.sh (PRISM_ALERTS_EMAIL secret).
PRISM_ALERTS_EMAIL_HOST=email-smtp.eu-west-1.amazonaws.com
PRISM_ALERTS_EMAIL_USER=
PRISM_ALERTS_EMAIL_PASSWORD=
# Optional SMTP tuning (defaults: port 465 + SSL for AWS SES; use STARTTLS + 587 for many providers)
# PRISM_ALERTS_EMAIL_PORT=587
# PRISM_ALERTS_EMAIL_STARTTLS=true
# Dev/test only: auto-create a disposable Ethereal inbox (calls api.nodemailer.com). Forbidden when PRISM_ENV=production.
# Also auto-enabled for ``--test-email`` in non-prod when SMTP creds are unset.
# PRISM_ALERTS_USE_ETHEREAL=true
# Base URL for threshold worker ``POST /stats`` and deactivate links
# API_URL=https://prism-api.ovio.org
# Anticipatory-action alert country (default: mozambique)
# AA_ALERT_COUNTRY=mozambique
# Verify TLS for worker HTTP calls to API and WFP data feeds (default: true)
# PRISM_ALERT_HTTP_VERIFY_SSL=true

PRISM_OIDC_ISSUER=https://ciam.auth.wfp.org/oauth2/oidcdiscovery/.well-known/openid-configuration
# Must match the redirect URI registered for the OIDC client (FastAPI public URL + path).
PRISM_OIDC_REDIRECT_URI=http://localhost/auth/callback
# These variables are generated by the WFP CIAM team when you register an OIDC client for the API
PRISM_OIDC_CLIENT_ID=
PRISM_OIDC_CLIENT_SECRET=
# Stable secret for signing the browser session cookie and OIDC state. Generate locally:
#   `openssl rand -hex 32` or `python -c 'import secrets; print(secrets.token_hex(32))'`
PRISM_SESSION_SECRET=
# Default one week session time
PRISM_SESSION_TTL_SECONDS=604800

# Local map export storage (optional — docker-compose.develop.yml sets RustFS defaults).
# EXPORT_MAP_S3_BUCKET=prism-dev
# AWS_ACCESS_KEY_ID=rustfsadmin
# AWS_SECRET_ACCESS_KEY=rustfsadmin
# AWS_ENDPOINT_URL=http://rustfs:9000          # server-side S3 (Docker network)
# AWS_PRESIGN_ENDPOINT_URL=http://localhost:9000  # presigned download URLs (browser)
