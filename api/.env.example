# Copy to .env and adjust. Used by the API, Alembic, and seed script when present.

# --- Alerts / auth database (required for admin + alerts features)
# PRISM_ALERTS_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# POSTGRES_PASSWORD=
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=54321
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres

# --- Admin UI: CIAM OIDC (omit or leave empty for local-only if using ADMIN_AUTH_DISABLED)
# Official docs: https://docs.ciam.auth.wfp.org/ (flows, login, getting started, errors).
#
# Issuer must match the "issuer" field from CIAM OpenID discovery (not necessarily the host root).
# If you pasted the discovery URL, include only the issuer base — or the API strips a trailing /.well-known/openid-configuration suffix.
# Discovery URL is always: {issuer}/.well-known/openid-configuration
# Example issuer (verify against your environment / CIAM guide):
# PRISM_OIDC_ISSUER=https://ciam.auth.wfp.org/oauth2/oidcdiscovery
# PRISM_OIDC_CLIENT_ID=
# PRISM_OIDC_CLIENT_SECRET=
# Must match the redirect URI registered for the OIDC client (FastAPI public URL + path).
# PRISM_OIDC_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
# PRISM_OIDC_SCOPES=openid profile email
# Optional: authorize URL `prompt` (e.g. `login`).
# PRISM_OIDC_AUTHORIZE_PROMPT=login
#
# After CIAM sign-out redirect (RP-initiated logout). Must be registered for the OIDC client.
# See https://docs.ciam.auth.wfp.org/login-workflows/#about-logout
# Typical value: `{public API URL}/auth/signed-out`
# PRISM_OIDC_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:8000/auth/signed-out
# Optional cookie name for storing id_token as id_token_hint (default prism_oidc_id_token). Note: very large id_tokens can exceed browser cookie size limits.
# PRISM_OIDC_ID_TOKEN_HINT_COOKIE_NAME=prism_oidc_id_token
# Stable secret for signing the browser session cookie and OIDC state. Generate locally:
#   openssl rand -hex 32
#   python -c 'import secrets; print(secrets.token_hex(32))'
# See api/README.md ("Session secret"). Omit in local dev to auto-generate an ephemeral key (not for production).
# PRISM_SESSION_SECRET=
# PRISM_SESSION_COOKIE_NAME=prism_session
# PRISM_SESSION_TTL_SECONDS=3600
# Defaults to secure cookies (HTTPS). Set false for plain HTTP local URLs (e.g. http://127.0.0.1:8000).
# PRISM_SESSION_COOKIE_SECURE=false
# PRISM_SESSION_COOKIE_SAMESITE=lax

# PRISM_OIDC_STATE_COOKIE_NAME=prism_oidc_state
# PRISM_OIDC_STATE_TTL_SECONDS=600

# Shown on /access-not-configured
# PRISM_ACCESS_SUPPORT_EMAIL=support@example.org

# Local dev only: bypasses OIDC for /admin (do not use in production).
# PRISM_ADMIN_AUTH_DISABLED=true

# When set to production (or prod), PRISM_SESSION_SECRET is required (same value on every replica / worker).
# PRISM_ENV=production
