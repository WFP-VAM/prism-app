PRISM_ALERTS_DATABASE_URL='postgresql://postgres:!ChangeMe!@127.0.0.1:54321/postgres'
PRISM_OIDC_ISSUER=https://ciam.auth.wfp.org/oauth2/oidcdiscovery/.well-known/openid-configuration
# Must match the redirect URI registered for the OIDC client (FastAPI public URL + path).
PRISM_OIDC_REDIRECT_URI=http://localhost/auth/callback
# These variables are generated by the WFP CIAM team when you register an OIDC client for the API
PRISM_OIDC_CLIENT_ID=
PRISM_OIDC_CLIENT_SECRET=
# Stable secret for signing the browser session cookie and OIDC state. Generate locally:
#   `openssl rand -hex 32` or `python -c 'import secrets; print(secrets.token_hex(32))'`
PRISM_SESSION_SECRET=
# Default one week session time
PRISM_SESSION_TTL_SECONDS=604800

# Local map export storage (optional — docker-compose.develop.yml sets MinIO defaults).
# EXPORT_MAP_S3_BUCKET=prism-dev
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT_URL=http://minio:9000          # server-side S3 (Docker network)
# AWS_PRESIGN_ENDPOINT_URL=http://localhost:9000  # presigned download URLs (browser)
