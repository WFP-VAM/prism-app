# Copy to `.env`. `src/db/pool.ts` loads it via dotenv for local `yarn` / `ts-node` (host port 54321).
PRISM_ALERTS_EMAIL_HOST=smtp.gmail.com
PRISM_ALERTS_EMAIL_USER=prism.alerts.wfp@gmail.com
PRISM_ALERTS_EMAIL_PASSWORD=test

# alerting/docker-compose.yml exposes Postgres on host port 54321 (container internal port is 5432).
POSTGRES_PORT=54321
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD="!ChangeMe!"

PRISM_OIDC_CLIENT_ID=<your client id>
PRISM_OIDC_CLIENT_SECRET=<your client secret>
PRISM_OIDC_REDIRECT_URI=<exact callback URL you registered>
