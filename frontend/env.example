REACT_APP_COUNTRY=mozambique
# Omit the next two lines to load dashboards from public/{REACT_APP_COUNTRY}/dashboard.json (add that file locally).
REACT_APP_DASHBOARD_CONFIG_BUCKET_URL=https://prism-dashboard-config.s3.us-east-2.amazonaws.com
# For local development against the dev bucket (see frontend/src/dashboardConfig/README.md):
# REACT_APP_DASHBOARD_CONFIG_DEV_BUCKET_URL=https://prism-dashboard-config-dev.s3.us-east-2.amazonaws.com
# REACT_APP_DASHBOARD_CONFIG_USE_DEV_BUCKET=true